# Application
APP_NAME=Django Monolith Template
APP_VERSION=1
DEBUG=false
PORT=8000
API_PREFIX=/api
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SHUTDOWN_TIMEOUT=10

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/django_monolith

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Logging
LOG_LEVEL=info
LOG_JSON=true

# CORS
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_LIMIT=100/m

# Metrics
METRICS_ENABLED=true

# pgAdmin (docker only)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
