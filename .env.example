# Application (dev default; review DEBUG, SECRET_KEY, and ALLOWED_HOSTS per environment)
APP_NAME=Django Monolith Template
APP_VERSION=1
DEBUG=false
PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=local-template-secret-key-with-enough-entropy-for-checks
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SHUTDOWN_TIMEOUT=10

# Database (required change in production; never reuse local credentials)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/django_monolith

# Redis (required change in production when Redis is not local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Logging (production normally uses info + json)
LOG_LEVEL=info
LOG_JSON=true

# CORS (required change in staging/production; never use wildcard origins)
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Rate Limiting (review per environment)
THROTTLE_LIMIT=100/m

# Metrics (disable only when another telemetry path owns metrics)
METRICS_ENABLED=true

# Deployment security (required change when HTTPS is terminated before Django)
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# pgAdmin (local docker only; not used by production compose)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
