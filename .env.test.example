# Application
APP_NAME=Django Monolith Template
APP_VERSION=1
DEBUG=false
PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=test-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SHUTDOWN_TIMEOUT=5

# Database (test database)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/django_monolith_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=60

# Logging
LOG_LEVEL=warning
LOG_JSON=false

# CORS
CORS_ENABLED=false
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_LIMIT=1000/m

# Metrics
METRICS_ENABLED=false

# Deployment security
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
